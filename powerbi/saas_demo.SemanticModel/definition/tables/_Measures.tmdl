	/// Dynamic title for Discount page
	measure 'Title - Discount Analysis' = "Discount Analysis | " & [Selected Period Label]
		isHidden
		displayFolder: Page Titles
		lineageTag: a991dadb-b98d-4410-9be7-01670219fd70

	/// Dynamic title for Trends page
	measure 'Title - Trends' = "Trends & Time Intelligence" & IF(HASONEVALUE(dim_date[year]), " - " & FORMAT(SELECTEDVALUE(dim_date[year]), "0"), "") & IF(HASONEVALUE(dim_date[quarter_label]), " " & SELECTEDVALUE(dim_date[quarter_label]), "")
		isHidden
		displayFolder: Page Titles
		lineageTag: fc1a4c73-58b3-4848-ba09-ad1c0d3318c4

	/// Dynamic title for Data Quality page
	measure 'Title - Data Quality' = "Data Quality Dashboard | " & [Selected Period Label] & " | Refreshed: " & FORMAT(NOW(), "DD-MMM-YYYY HH:NN")
		isHidden
		displayFolder: Page Titles
		lineageTag: 4a34e249-59f5-4796-8896-e3c945e7d007

	/// Dynamic title for Validation page
	measure 'Title - Validation' = "Validation & Reconciliation | " & [Selected Period Label]
		isHidden
		displayFolder: Page Titles
		lineageTag: 3097cccc-a72b-4cc0-8f18-4865490cec7b

	/// Concatenated product summary for tooltip page
	measure 'Tooltip Product Summary' =
			VAR _name = SELECTEDVALUE(dim_product[drug_name], "Multiple Products")
			VAR _brand = SELECTEDVALUE(dim_product[drug_brand], "")
			VAR _cat = SELECTEDVALUE(dim_product[drug_category], "")
			VAR _status = SELECTEDVALUE(dim_product[drug_status], "")
			VAR _rev = FORMAT([Net Revenue], "#,##0")
			VAR _qty = FORMAT([Total Quantity], "#,##0")
			VAR _rank = FORMAT([Product Revenue Rank], "#,##0")
			RETURN
			    _name
			    & IF(_brand <> "", UNICHAR(10) & "Brand: " & _brand, "")
			    & IF(_cat <> "", UNICHAR(10) & "Category: " & _cat, "")
			    & IF(_status <> "", UNICHAR(10) & "Status: " & _status, "")
			    & UNICHAR(10) & "Revenue: " & _rev
			    & UNICHAR(10) & "Quantity: " & _qty
			    & IF(NOT ISBLANK([Product Revenue Rank]), UNICHAR(10) & "Rank: #" & _rank, "")
		displayFolder: Tooltips
		lineageTag: 89ead2df-1afd-47af-a7b4-62ea9c5eebfd

	/// Concatenated customer summary for tooltip page
	measure 'Tooltip Customer Summary' =
			VAR _name = SELECTEDVALUE(dim_customer[customer_name], "Multiple Customers")
			VAR _rev = FORMAT([Net Revenue], "#,##0")
			VAR _invCnt = FORMAT([Unique Invoices], "#,##0")
			VAR _avgInv = FORMAT([Avg Invoice Value], "#,##0.00")
			VAR _lastTx = FORMAT([Last Transaction Date], "DD-MMM-YYYY")
			RETURN
			    _name
			    & UNICHAR(10) & "Revenue: " & _rev
			    & UNICHAR(10) & "Invoices: " & _invCnt
			    & UNICHAR(10) & "Avg Invoice: " & _avgInv
			    & IF(NOT ISBLANK([Last Transaction Date]), UNICHAR(10) & "Last Txn: " & _lastTx, "")
		displayFolder: Tooltips
		lineageTag: 01839481-1324-4e78-ba8c-ed52abb05397

	/// Concatenated month summary for tooltip page
	measure 'Tooltip Month Summary' =
			VAR _period = SELECTEDVALUE(dim_date[year_month], "Multiple Periods")
			VAR _rev = FORMAT([Net Revenue], "#,##0")
			VAR _qty = FORMAT([Total Quantity], "#,##0")
			VAR _inv = FORMAT([Unique Invoices], "#,##0")
			VAR _cust = FORMAT([Unique Customers], "#,##0")
			VAR _mom = [Revenue MoM Badge]
			RETURN
			    _period
			    & UNICHAR(10) & "Revenue: " & _rev
			    & UNICHAR(10) & "Quantity: " & _qty
			    & UNICHAR(10) & "Invoices: " & _inv
			    & UNICHAR(10) & "Customers: " & _cust
			    & IF(_mom <> "--", UNICHAR(10) & "MoM: " & _mom, "")
		displayFolder: Tooltips
		lineageTag: 2136692a-68c3-419d-82fe-21dc189768fa

	/// Most recent transaction date in current filter context
	measure 'Last Transaction Date' = MAX(dim_date[full_date])
		formatString: DD-MMM-YYYY
		displayFolder: Tooltips
		lineageTag: 223e097b-bbf9-4a1a-9d4d-b7848fa9fa7c

	/// Unicode arrow badge for MoM revenue change
	measure 'Revenue MoM Arrow' =
			VAR _dir = [Revenue MoM Direction]
			VAR _pct = [Revenue MoM %]
			RETURN
			    IF(
			        ISBLANK(_pct), "--",
			        SWITCH(
			            _dir,
			            1, UNICHAR(9650) & " " & FORMAT(_pct, "0.0%"),
			            -1, UNICHAR(9660) & " " & FORMAT(_pct, "0.0%"),
			            UNICHAR(9654) & " " & FORMAT(_pct, "0.0%")
			        )
			    )
		displayFolder: Conditional Formatting
		lineageTag: 82e00e3c-79fe-443a-b8c4-9b9f59ad03fa

	/// Unicode arrow badge for YoY revenue change
	measure 'Revenue YoY Arrow' =
			VAR _dir = [Revenue YoY Direction]
			VAR _pct = [Revenue YoY %]
			RETURN
			    IF(
			        ISBLANK(_pct), "--",
			        SWITCH(
			            _dir,
			            1, UNICHAR(9650) & " " & FORMAT(_pct, "0.0%"),
			            -1, UNICHAR(9660) & " " & FORMAT(_pct, "0.0%"),
			            UNICHAR(9654) & " " & FORMAT(_pct, "0.0%")
			        )
			    )
		displayFolder: Conditional Formatting
