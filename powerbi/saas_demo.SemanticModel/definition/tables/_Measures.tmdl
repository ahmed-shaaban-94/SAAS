	/// Net Revenue resolved at governorate level for shape map
	measure 'Revenue by Governorate' =
			IF(
			    HASONEVALUE(dim_site[governorate]),
			    [Net Revenue],
			    BLANK()
			)
		formatString: #,##0
		displayFolder: Report Helpers
		lineageTag: 538b0bef-9967-4004-9155-a76c89a8dde8

	/// Returns 1 when Detail view is selected, 0 for Summary
	measure 'Is Detail View' =
			IF(
			    SELECTEDVALUE('_ViewToggle'[View], "Summary") = "Detail",
			    1,
			    0
			)
		formatString: 0
		isHidden
		displayFolder: Report Helpers
		lineageTag: ca7ebc14-6820-4d89-a9bf-b4763e9c7f2d

	/// Returns the selected display mode for KPI cards
	measure 'KPI Display Mode' = SELECTEDVALUE('_KPIDisplayMode'[Display Mode], "Absolute")
		isHidden
		displayFolder: Report Helpers
		lineageTag: cadbab19-0e74-4925-b475-0250651af593

	/// Switches between absolute Net Revenue and MoM % based on toggle
	measure 'KPI Dynamic Value' =
			IF(
			    [KPI Display Mode] = "Percentage",
			    [Revenue MoM %],
			    [Net Revenue]
			)
		formatStringExpression: =IF([KPI Display Mode] = "Percentage", "0.00%", "#,##0.00")
		displayFolder: Report Helpers
		lineageTag: 0dde5298-cea7-449a-9eed-85ac4d72afa6

	/// Percentage of customers with insurance transactions
	measure 'Insurance Customer %' =
			DIVIDE(
			    [Insurance Customers],
			    [Unique Customers],
			    0
			)
		formatString: 0.00%
		displayFolder: Customer Analytics
		lineageTag: f3c7e4d0-e118-4be9-b272-68f85bb258f8

	/// Percentage of distinct products sold that have Active status (count-based)
	measure 'Active Product Count %' =
			VAR _activeCount =
			    CALCULATE(
			        DISTINCTCOUNT(fct_sales[product_key]),
			        dim_product[drug_status] = "Active"
			    )
			VAR _totalCount = [Unique Products Sold]
			RETURN
			    DIVIDE(_activeCount, _totalCount, 0)
		formatString: 0.00%
		displayFolder: Product Analytics
		lineageTag: 77e6f0b8-ed27-40e1-8f74-940cfa641653

	column Value
		lineageTag: d898370a-2dcc-4987-bfd4-51fd3e15ef82
		isNameInferred
		sourceColumn: [Value]

	partition _Measures = calculated
		mode: import
		source = {BLANK()}

