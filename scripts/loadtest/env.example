# Load test target configuration. Copy to .env and fill in.
# Never commit .env — it contains tenant-scoped JWTs.

# API base URL (no trailing slash).
BASE_URL=http://localhost:8000

# JWT Bearer token for an authenticated user in the target tenant.
# Mint via Clerk dev dashboard OR API (see docs/RUNBOOK.md).
AUTH_TOKEN=

# Tenant ID the JWT is scoped to.
TENANT_ID=1

# POS-specific: pharmacist PIN for checkout flows that require it.
POS_PIN=1234
