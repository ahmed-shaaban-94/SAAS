# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
ENV/

# Environment
.env
**/.env

# Data files (keep structure, ignore actual data)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/
notebooks/*.ipynb

# Coverage
htmlcov/
.coverage
.coverage.*

# pytest
.pytest_cache/

# dbt
dbt/logs/
dbt/target/
dbt/.user.yml
dbt/dbt_packages/

# Frontend
frontend/node_modules/
frontend/.next/
frontend/.env*.local
frontend/tsconfig.tsbuildinfo

# Claude Code
.claude/settings.local.json
.claude/worktrees/

# Waitlist data (frontend)
frontend/waitlist.json

# TLS/SSL certificates and keys
*.pem
*.key
*.crt
*.p12

# Database backups
backups/
coverage.xml

# Local MCP server config (machine-specific paths)
.mcp.json

# Second Brain — sessions and index are local-only (auto-generated per-machine)
# session-log.csv is shared and tracked. decisions/ and incidents/ are tracked.
docs/brain/sessions/*
!docs/brain/sessions/.gitkeep
docs/brain/_INDEX.md
# session-log.csv is intentionally NOT ignored — it's the shared team log

# Git worktrees
.worktrees/
