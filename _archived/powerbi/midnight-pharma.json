        "columnHeaders": [{"fontColor": {"solid": {"color": "#E6EDF3"}}, "backColor": {"solid": {"color": "#21262D"}}, "fontSize": 11}],
        "rowHeaders": [{"fontColor": {"solid": {"color": "#A8B3BD"}}, "backColor": {"solid": {"color": "#161B22"}}, "fontSize": 10}],
        "values": [{"fontColor": {"solid": {"color": "#A8B3BD"}}, "backColor": {"solid": {"color": "#161B22"}}, "fontSize": 10}],
