    },
    "shape": {
      "*": {
        "fill": [{"fillColor": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "line": [{"lineColor": {"solid": {"color": "#30363D"}}, "weight": 1}]
      }
    },
    "actionButton": {
      "*": {
        "fill": [{"fillColor": {"solid": {"color": "#21262D"}}, "transparency": 0}],
        "outline": [{"color": {"solid": {"color": "#30363D"}}, "weight": 1}],
        "text": [{"fontColor": {"solid": {"color": "#A8B3BD"}}, "fontSize": 10}]
      }
    },
    "textbox": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 100}]
      }
    }
  }
