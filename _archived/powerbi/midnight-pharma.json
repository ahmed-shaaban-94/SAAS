        "total": [{"fontColor": {"solid": {"color": "#E6EDF3"}}, "backColor": {"solid": {"color": "#21262D"}}, "fontSize": 10}],
        "grid": [{"gridHorizontalColor": {"solid": {"color": "#30363D"}}, "gridVerticalColor": {"solid": {"color": "#30363D"}}, "rowPadding": 4}]
