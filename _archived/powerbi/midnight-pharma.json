        "grid": [{"gridHorizontalColor": {"solid": {"color": "#30363D"}}, "gridVerticalColor": {"solid": {"color": "#30363D"}}, "rowPadding": 4}]
      }
    },
    "barChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}],
        "labels": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 10}]
      }
    },
    "clusteredBarChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}]
      }
    },
    "columnChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}],
        "labels": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 10}]
      }
    },
    "clusteredColumnChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}]
      }
    },
    "lineChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}],
        "labels": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 10}]
      }
    },
    "areaChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}]
      }
    },
    "lineClusteredColumnComboChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}]
      }
    },
    "lineStackedColumnComboChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}]
      }
    },
    "waterfallChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "sentimentColors": [{"increaseFill": {"solid": {"color": "#2E7D32"}}, "decreaseFill": {"solid": {"color": "#C62828"}}, "totalFill": {"solid": {"color": "#00BFA5"}}}]
      }
    },
    "donutChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "labels": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 10}]
      }
    },
    "pieChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
