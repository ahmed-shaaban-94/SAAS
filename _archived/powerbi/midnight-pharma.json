{
  "name": "Midnight Pharma",
  "dataColors": ["#00BFA5", "#2196F3", "#FFB300", "#E91E63", "#9C27B0", "#FF5722", "#00ACC1", "#8BC34A", "#795548", "#607D8B"],
  "background": "#0D1117",
  "foreground": "#E6EDF3",
  "tableAccent": "#00BFA5",
  "maximum": "#2E7D32",
  "center": "#9E9E9E",
  "minimum": "#C62828",
  "good": "#2E7D32",
  "neutral": "#9E9E9E",
  "bad": "#C62828",
  "textClasses": {
    "callout": {"fontSize": 28, "fontFace": "Segoe UI Semibold, wf_segoe-ui_semibold, helvetica, arial, sans-serif", "color": "#E6EDF3"},
    "title": {"fontSize": 12, "fontFace": "Segoe UI Semibold, wf_segoe-ui_semibold, helvetica, arial, sans-serif", "color": "#E6EDF3"},
    "header": {"fontSize": 11, "fontFace": "Segoe UI Semibold, wf_segoe-ui_semibold, helvetica, arial, sans-serif", "color": "#E6EDF3"},
    "label": {"fontSize": 10, "fontFace": "Segoe UI, wf_segoe-ui_normal, helvetica, arial, sans-serif", "color": "#A8B3BD"}
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "border": [{"show": true, "color": {"solid": {"color": "#30363D"}}, "radius": 4}],
        "title": [{"show": true, "fontColor": {"solid": {"color": "#E6EDF3"}}, "fontSize": 12, "fontFamily": "Segoe UI Semibold, wf_segoe-ui_semibold, helvetica, arial, sans-serif", "alignment": "left"}],
        "subTitle": [{"show": true, "fontColor": {"solid": {"color": "#A8B3BD"}}, "fontSize": 10, "fontFamily": "Segoe UI, wf_segoe-ui_normal, helvetica, arial, sans-serif"}],
        "legend": [{"labelColor": {"solid": {"color": "#A8B3BD"}}, "fontSize": 9, "fontFamily": "Segoe UI, wf_segoe-ui_normal, helvetica, arial, sans-serif"}],
        "categoryAxis": [{"labelColor": {"solid": {"color": "#A8B3BD"}}, "fontSize": 9, "gridlineColor": {"solid": {"color": "#21262D"}}, "lineColor": {"solid": {"color": "#A8B3BD"}}}],
        "valueAxis": [{"labelColor": {"solid": {"color": "#A8B3BD"}}, "fontSize": 9, "gridlineColor": {"solid": {"color": "#21262D"}}, "lineColor": {"solid": {"color": "#A8B3BD"}}}],
        "labels": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 10}]
      }
    },
    "card": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "calloutValue": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 28, "fontFamily": "Segoe UI Semibold, wf_segoe-ui_semibold, helvetica, arial, sans-serif"}],
        "categoryLabel": [{"show": true, "color": {"solid": {"color": "#A8B3BD"}}, "fontSize": 10}]
      }
    },
    "multiRowCard": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataLabels": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 14}],
        "categoryLabels": [{"show": true, "color": {"solid": {"color": "#A8B3BD"}}, "fontSize": 10}],
        "cardTitle": [{"color": {"solid": {"color": "#A8B3BD"}}, "fontSize": 10}]
      }
    },
    "tableEx": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "columnHeaders": [{"fontColor": {"solid": {"color": "#E6EDF3"}}, "backColor": {"solid": {"color": "#21262D"}}, "fontSize": 11}],
