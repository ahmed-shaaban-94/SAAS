        "categoryLabels": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 10}]
      }
    },
    "scatterChart": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}]
      }
    },
    "map": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}]
      }
    },
    "filledMap": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}}]
      }
    },
    "gauge": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "dataPoint": [{"fill": {"solid": {"color": "#00BFA5"}}, "target": {"solid": {"color": "#A8B3BD"}}}],
        "calloutValue": [{"color": {"solid": {"color": "#E6EDF3"}}, "fontSize": 28}]
      }
    },
    "slicer": {
      "*": {
        "background": [{"color": {"solid": {"color": "#161B22"}}, "transparency": 0}],
        "data": [{"fontColor": {"solid": {"color": "#A8B3BD"}}, "fontSize": 10}],
        "header": [{"fontColor": {"solid": {"color": "#E6EDF3"}}, "background": {"solid": {"color": "#161B22"}}, "fontSize": 11}]
