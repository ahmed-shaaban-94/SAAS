/// Staff/personnel dimension (SCD Type 1).
table dim_staff
	lineageTag: f7b7b8d5-472e-47c5-adaa-04c11c3e3874

	column staff_key
		dataType: int64
		isHidden
		lineageTag: bbacdb5a-703d-48a9-a4d4-4025f06facbc
		summarizeBy: none
		sourceColumn: staff_key

	column staff_id
		dataType: string
		lineageTag: e04e67bf-9273-4074-a849-9268196d2aea
		sourceColumn: staff_id

	column staff_name
		dataType: string
		lineageTag: c42ca9ce-04c6-441c-8e3c-a735869a1fb4
