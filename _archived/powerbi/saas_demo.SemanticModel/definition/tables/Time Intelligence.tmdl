table 'Time Intelligence'
	lineageTag: 77db8b78-a5c1-4c90-8c81-eeff90a1240e

	/// Applies time intelligence to any measure. Use as slicer or axis.
	calculationGroup
		precedence: 10

		/// Current period value (no transformation)
		calculationItem Current = SELECTEDMEASURE()

			formatStringDefinition = SELECTEDMEASUREFORMATSTRING()

		/// Month-to-date
		calculationItem MTD =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESMTD(dim_date[full_date])
				)

			formatStringDefinition = SELECTEDMEASUREFORMATSTRING()

		/// Quarter-to-date
		calculationItem QTD =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESQTD(dim_date[full_date])
				)

			formatStringDefinition = SELECTEDMEASUREFORMATSTRING()

		/// Year-to-date
		calculationItem YTD =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESYTD(dim_date[full_date])
				)

			formatStringDefinition = SELECTEDMEASUREFORMATSTRING()

		/// Previous month value
		calculationItem 'Previous Month' =
				CALCULATE(
				    SELECTEDMEASURE(),
				    PREVIOUSMONTH(dim_date[full_date])
				)

			formatStringDefinition = SELECTEDMEASUREFORMATSTRING()

		/// Previous quarter value
		calculationItem 'Previous Quarter' =
				CALCULATE(
				    SELECTEDMEASURE(),
				    PREVIOUSQUARTER(dim_date[full_date])
				)

			formatStringDefinition = SELECTEDMEASUREFORMATSTRING()

		/// Same period last year
		calculationItem 'Previous Year' =
				CALCULATE(
				    SELECTEDMEASURE(),
				    SAMEPERIODLASTYEAR(dim_date[full_date])
				)

			formatStringDefinition = SELECTEDMEASUREFORMATSTRING()

		/// Month-over-month % change
		calculationItem 'MoM %' =
				VAR _current = SELECTEDMEASURE()
				VAR _previous = CALCULATE(
				    SELECTEDMEASURE(),
				    PREVIOUSMONTH(dim_date[full_date])
				)
				RETURN
				    DIVIDE(_current - _previous, ABS(_previous), BLANK())

			formatStringDefinition = "0.00%"

		/// Quarter-over-quarter % change
		calculationItem 'QoQ %' =
				VAR _current = SELECTEDMEASURE()
				VAR _previous = CALCULATE(
				    SELECTEDMEASURE(),
				    PREVIOUSQUARTER(dim_date[full_date])
				)
				RETURN
				    DIVIDE(_current - _previous, ABS(_previous), BLANK())

			formatStringDefinition = "0.00%"

		/// Year-over-year % change
		calculationItem 'YoY %' =
				VAR _current = SELECTEDMEASURE()
				VAR _previous = CALCULATE(
				    SELECTEDMEASURE(),
				    SAMEPERIODLASTYEAR(dim_date[full_date])
				)
				RETURN
				    DIVIDE(_current - _previous, ABS(_previous), BLANK())

			formatStringDefinition = "0.00%"

		/// Rolling 3-month average
		calculationItem 'Rolling 3M Avg' =
				VAR _last3months = CALCULATE(
				    SELECTEDMEASURE(),
				    DATESINPERIOD(dim_date[full_date], MAX(dim_date[full_date]), -3, MONTH)
				)
				VAR _monthCount = CALCULATE(
				    DISTINCTCOUNT(dim_date[year_month]),
				    DATESINPERIOD(dim_date[full_date], MAX(dim_date[full_date]), -3, MONTH)
				)
				RETURN
				    DIVIDE(_last3months, _monthCount, BLANK())

			formatStringDefinition = SELECTEDMEASUREFORMATSTRING()

	column 'Time Intelligence'
		dataType: string
		lineageTag: c93b9753-d2d6-461a-8060-e4fb993dbe60

	partition 'Partition_Time Intelligence' = calculationGroup

