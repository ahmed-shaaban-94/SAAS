/// Calendar dimension (2023-2025). Egypt weekend = Fri & Sat.
table dim_date
	lineageTag: 552f3b9f-017d-4919-8698-a01616e3fb48
	dataCategory: Time

	column date_key
		dataType: int64
		isHidden
		lineageTag: b22b00e0-7396-4102-ac06-3511171cc2b9
		summarizeBy: none
		sourceColumn: date_key

	column full_date
		dataType: dateTime
		isUnique
		isKey
		formatString: yyyy-MM-dd
		lineageTag: c1e82090-0357-4f53-80f2-753fddd757c3
		summarizeBy: none
		sourceColumn: full_date

		annotation UnderlyingDateTimeDataType = Date

		annotation SummarizationSetBy = Automatic

	column year
		dataType: int64
		lineageTag: 705061b8-7323-4629-a920-1292fe4201a8
		summarizeBy: none
		sourceColumn: year

	column quarter
		dataType: int64
		lineageTag: a55dc66a-4c67-446b-af20-db5851178871
		summarizeBy: none
		sourceColumn: quarter

	column month
		dataType: int64
		isHidden
		lineageTag: 15ab9229-fec7-483f-9baf-70f4df331cc8
		summarizeBy: none
		sourceColumn: month

	column month_name
		dataType: string
		lineageTag: aed9fc45-e8f2-4e1d-9276-e8fb8006f3a3
		sourceColumn: month_name
		sortByColumn: month

	column day_of_week
		dataType: int64
		isHidden
		lineageTag: 6853f26f-45fa-4985-b12b-1b88d17a94f0
		summarizeBy: none
		sourceColumn: day_of_week

	column day_name
		dataType: string
		lineageTag: 7eac8eb8-d60c-4089-be37-b2d249ecb247
		sourceColumn: day_name
		sortByColumn: day_of_week

	column is_weekend
		dataType: boolean
		lineageTag: 74dc7834-3f1e-43e3-bfba-13049c52558c
		sourceColumn: is_weekend

	column week_number
		dataType: int64
		lineageTag: a865d72c-9e63-42cd-bdbd-75d67043ecac
		summarizeBy: none
		sourceColumn: week_number

	column week_start_date
		dataType: dateTime
		formatString: yyyy-MM-dd
		lineageTag: 9cb9116b-e852-4c8d-a228-c2e8dcc60bf7
		summarizeBy: none
		sourceColumn: week_start_date

		annotation UnderlyingDateTimeDataType = Date

		annotation SummarizationSetBy = Automatic

	column year_week
		dataType: string
		lineageTag: 262903cd-2dd3-4db3-ab12-8c1f0db0dd1a
		sourceColumn: year_week

	column quarter_label
		dataType: string
		lineageTag: d0c0f660-87da-42d4-8e8f-7c2b9a42ced4
		sourceColumn: quarter_label

	column year_month
		dataType: string
		lineageTag: 6495935b-c8a9-4ffc-ba14-94d636b49692
		sourceColumn: year_month

	/// Year > Quarter > Month drill-down
	hierarchy 'Time Hierarchy'
		lineageTag: ccc29b2e-6c61-4e64-92d4-b9144f1b9ac1

		level Year
			lineageTag: 4cf90f3c-dccf-4b4d-b8dd-0c5a55c911f2
			column: year

		level Quarter
			lineageTag: 2de445f9-3edd-4727-b8c0-9610c759ea6c
			column: quarter_label

		level Month
			lineageTag: c4475890-59a7-4480-b0f5-db6b8f63a6e9
			column: year_month

	partition dim_date = m
		mode: import
		source =
				let
				    Source = PostgreSQL.Database("localhost:5432", "datapulse"),
				    tbl = Source{[Schema="public_marts",Item="dim_date"]}[Data]
				in
				    tbl

	annotation PBI_ResultType = Table

