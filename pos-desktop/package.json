{
  "name": "datapulse-pos",
  "version": "1.0.0",
  "description": "DataPulse POS — Pharmacy Point of Sale Desktop App",
  "main": "dist/electron/main.js",
  "author": "DataPulse <support@smartdatapulse.tech>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "tsc -p tsconfig.json && electron .",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder --win",
    "package:dir": "npm run build && electron-builder --win --dir",
    "test": "echo \"tests land with M2 proper (jest + ts-jest)\" && exit 0"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.6.0"
  },
  "_m2Notes": {
    "_doc": "Native/runtime deps declared but NOT installed in M2 pre-work. Run `npm install <pkg>` in M2 proper after Windows Build Tools is set up.",
    "plannedRuntimeDeps": {
      "better-sqlite3": "^11.3.0",
      "node-thermal-printer": "^4.4.0",
      "@journeyapps/sqlcipher": "^5.3.1",
      "electron-updater": "^6.3.0",
      "serialport": "^12.0.0"
    },
    "plannedWindowsDeps": {
      "win-dpapi": "^1.0.0"
    },
    "plannedDevDeps": {
      "@types/node": "^22.0.0",
      "@types/better-sqlite3": "^7.6.0",
      "jest": "^29.7.0",
      "ts-jest": "^29.2.0",
      "@types/jest": "^29.5.0",
      "electron-rebuild": "^3.2.0"
    }
  }
}
