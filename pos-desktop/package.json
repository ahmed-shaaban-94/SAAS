{
  "name": "datapulse-pos",
  "version": "3.0.3",
  "description": "DataPulse POS — Pharmacy Point of Sale Desktop App",
  "main": "dist/electron/main.js",
  "author": "DataPulse <support@smartdatapulse.tech>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.json && electron .\"",
    "dev:vite": "vite",
    "dev:electron": "tsc -p tsconfig.json && electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.json && node scripts/copy-assets.js",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder --win",
    "package:dir": "npm run build && electron-builder --win --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:electron": "jest --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@fontsource/cairo": "^5.2.7",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.1.0",
    "@sentry/electron": "^5.11.0",
    "@sentry/react": "^8.0.0",
    "@tanstack/react-query": "^5.0.0",
    "better-sqlite3": "^12.9.0",
    "bwip-js": "^4.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "focus-trap-react": "^12.0.1",
    "lucide-react": "^0.400.0",
    "next-themes": "^0.4.6",
    "node-thermal-printer": "^4.6.0",
    "pino": "^9.14.0",
    "pino-roll": "^3.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.0.0",
    "sonner": "^1.5.0",
    "swr": "^2.3.3",
    "tailwind-merge": "^2.6.0",
    "use-debounce": "^10.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-rebuild": "^3.2.9",
    "happy-dom": "^20.8.9",
    "jest": "^30.3.0",
    "openapi-typescript": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.9",
    "typescript": "^5.6.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.0"
  }
}
