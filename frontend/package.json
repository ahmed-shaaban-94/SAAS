{
  "name": "datapulse-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:budget": "next build && node scripts/check-bundle-budget.js",
    "start": "next start",
    "lint": "next lint",
    "lint:strict": "next lint --max-warnings=0",
    "test:e2e": "playwright test",
    "codegen": "openapi-typescript ../contracts/openapi.json -o src/generated/api.ts",
    "codegen:check": "openapi-typescript ../contracts/openapi.json -o /tmp/api.gen.ts && diff -u src/generated/api.ts /tmp/api.gen.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.1.0",
    "@sentry/nextjs": "^8.0.0",
    "bwip-js": "^4.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.400.0",
    "next": "^15.3.0",
    "next-auth": "^4.24.13",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.367.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-grid-layout": "^2.2.3",
    "recharts": "^2.15.3",
    "swr": "^2.3.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.3.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bwip-js": "^3.2.3",
    "@types/node": "20.19.37",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.9.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "protobufjs": ">=7.5.5",
    "dompurify": ">=3.4.0"
  },
  "bundlesize": [
    {
      "path": ".next/static/chunks/pages/_app*.js",
      "maxSize": "120 kB",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/main*.js",
      "maxSize": "50 kB",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/framework*.js",
      "maxSize": "50 kB",
      "compression": "gzip"
    }
  ]
}
