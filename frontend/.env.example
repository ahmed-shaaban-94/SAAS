# --- API ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Auth provider (must match backend AUTH_PROVIDER) ---
NEXT_PUBLIC_AUTH_PROVIDER=auth0

# --- Auth0 OIDC (NextAuth) — used when NEXT_PUBLIC_AUTH_PROVIDER=auth0 ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://api.datapulse.tech
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate-with: openssl rand -hex 32>

# --- Clerk (used when NEXT_PUBLIC_AUTH_PROVIDER=clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
# JWT template name emitting `tenant_id` + `roles` (must match backend).
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=datapulse
# Used by middleware CSP to allow-list Clerk's JS origin.
NEXT_PUBLIC_CLERK_FRONTEND_API=https://your-slug.clerk.accounts.dev

# --- Sentry (Error Tracking) ---
NEXT_PUBLIC_SENTRY_DSN=https://your-frontend-dsn@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
