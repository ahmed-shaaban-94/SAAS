{
  "title": "DataPulse API",
  "uid": "datapulse-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"datapulse-api\"}[5m]))",
          "legendFormat": "Total req/s",
          "datasource": "Prometheus"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"datapulse-api\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors/s",
          "datasource": "Prometheus"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"datapulse-api\", status=~\"4..\"}[5m]))",
          "legendFormat": "4xx/s",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "P95 Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"datapulse-api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"datapulse-api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"datapulse-api\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"datapulse-api\"}[5m]))",
          "legendFormat": "5xx %",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "4xx Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"datapulse-api\", status=~\"4..\"}[5m])) / sum(rate(http_requests_total{job=\"datapulse-api\"}[5m]))",
          "legendFormat": "4xx %",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "DB Pool: Checked Out / Total",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "datapulse_db_pool_checked_out",
          "legendFormat": "Checked out",
          "datasource": "Prometheus"
        },
        {
          "expr": "datapulse_db_pool_size_total",
          "legendFormat": "Pool size",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Active Alerts",
      "type": "alertlist",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "options": {
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": ["alertname"],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "firing": true, "pending": true }
      }
    }
  ]
}
