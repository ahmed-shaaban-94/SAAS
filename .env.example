# PostgreSQL
POSTGRES_USER=datapulse
POSTGRES_PASSWORD=<choose-a-strong-password>
POSTGRES_DB=datapulse
DATABASE_URL=postgresql://datapulse:<choose-a-strong-password>@localhost:5432/datapulse

# pgAdmin
PGADMIN_EMAIL=admin@datapulse.dev
PGADMIN_PASSWORD=<choose-a-strong-password>

# Paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
PARQUET_DIR=data/processed/parquet
RAW_SALES_PATH=E:/Data Analysis/sales/RAW FULL

# Limits
MAX_FILE_SIZE_MB=500
MAX_ROWS=10000000
MAX_COLUMNS=200
BRONZE_BATCH_SIZE=50000

# API Authentication
API_KEY=<generate-with: openssl rand -hex 32>

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# --- Phase 2: Automation ---

# n8n (built-in signup on first access — basic auth deprecated in n8n 1.x+)
N8N_ENCRYPTION_KEY=<generate-with: openssl rand -hex 32>

# Redis (internal, used by n8n queue mode when enabled)
REDIS_PASSWORD=<generate-with: openssl rand -hex 32>

# OpenRouter (AI-Light — free tier)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=openrouter/free

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email notifications
NOTIFICATION_EMAIL=alerts@datapulse.dev

# --- Metabase (Self-hosted BI) ---
# No extra config needed — uses POSTGRES_* credentials above
# Access at http://localhost:3001

# --- Keycloak (Auth / OAuth2 / OIDC) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<choose-a-strong-password>
# Access at http://localhost:8080

# --- Grafana (Monitoring Dashboards) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<choose-a-strong-password>
# Access at http://localhost:3002

# --- Prometheus ---
# No auth needed — internal metrics collection
# Access at http://localhost:9090
