# PostgreSQL
POSTGRES_USER=datapulse
POSTGRES_PASSWORD=<choose-a-strong-password>
POSTGRES_DB=datapulse
DATABASE_URL=postgresql://datapulse:<choose-a-strong-password>@localhost:5432/datapulse

# Brain MCP — automated SSH tunnel to droplet PostgreSQL (optional)
# When BRAIN_SSH_HOST is set, the brain MCP server and stop hook automatically
# open an SSH tunnel to reach the droplet's PostgreSQL. No port needs to be
# exposed on the server. Uses your existing SSH key.
# Leave empty for local-only dev. Fill only on operator machines that tunnel
# to the deployment database.
BRAIN_SSH_HOST=
BRAIN_SSH_USER=root
BRAIN_SSH_KEY=~/.ssh/id_ed25519
BRAIN_DB_USER=datapulse
BRAIN_DB_PASSWORD=<same-as-POSTGRES_PASSWORD>
BRAIN_DB_NAME=datapulse
# Read-only role password (used by migration 002). Required and must be stable.
DB_READER_PASSWORD=<choose-a-strong-fixed-password>

# Paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
PARQUET_DIR=data/processed/parquet
RAW_SALES_PATH=/path/to/your/sales/data

# Limits
MAX_FILE_SIZE_MB=500
MAX_ROWS=10000000
MAX_COLUMNS=200
BRONZE_BATCH_SIZE=50000

# Deployment mode — AUTHORITATIVE flag for security-sensitive gates.
# One of: development, test, staging, production.
# Keep at `development` for local .env (this file is copied to .env for
# dev work). On real deployments, set `APP_ENV=production` in the host
# environment or deploy-time .env — leaving it at `development` on a
# production host disables the startup auth guard (see RUNBOOK §7, #537).
APP_ENV=development

# API Authentication
API_KEY=<generate-with: openssl rand -hex 32>

# Auto-elevate these emails to owner/admin role on first login (comma-separated)
OWNER_EMAILS=owner@example.com
ADMIN_EMAILS=admin@example.com

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# --- Phase 2: Automation ---

# n8n (built-in signup on first access — basic auth deprecated in n8n 1.x+)
N8N_ENCRYPTION_KEY=<generate-with: openssl rand -hex 32>

# Redis (shared by n8n + API cache)
REDIS_PASSWORD=<generate-with: openssl rand -hex 32>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# OpenRouter (AI-Light — free tier)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=openrouter/free

# Brain (session memory) — embedding model for semantic search
# Uses OpenRouter API key above. Set to empty to disable semantic search (FTS still works).
BRAIN_EMBED_MODEL=openai/text-embedding-3-small

# --- Sentry (Error Tracking) ---
# Backend DSN (FastAPI project in Sentry)
SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=development
# Frontend DSN (Next.js project in Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://your-frontend-dsn@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email notifications
NOTIFICATION_EMAIL=alerts@datapulse.dev

# --- Auth provider ---
# Clerk is the sole supported IdP.
AUTH_PROVIDER=clerk

# --- Clerk ---
# Get the values from Clerk Dashboard → API Keys.
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_FRONTEND_API=https://your-slug.clerk.accounts.dev
CLERK_JWT_ISSUER=https://your-slug.clerk.accounts.dev
# Optional — set only if you configured an audience on the JWT template.
CLERK_JWT_AUDIENCE=
# JWT template name — the template must emit `tenant_id` + `roles` claims
# (see scripts/clerk_setup.py). Default: "datapulse".
CLERK_JWT_TEMPLATE=datapulse

# --- Stripe (Billing) ---
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=price_your-price-id
BILLING_BASE_URL=https://smartdatapulse.tech

# ── Arq distributed task queue ──────────────────────────────────────────────
# Queue list key inside Redis (db 1). Keep distinct from cache (db 0).
ARQ_QUEUE_NAME=datapulse:queries

# Reject API requests with 503 when queued+running jobs exceed this number.
# Set to 0 to disable the global queue-depth guard (per-process semaphore
# remains active).
ARQ_QUEUE_DEPTH_LIMIT=100

# Per-worker concurrency. Multiply by replicas for total parallelism.
ARQ_MAX_JOBS=10

# Hard timeout for a single query job in seconds. Should be >= the Postgres
# statement_timeout configured for the tenant session (default 270s).
ARQ_JOB_TIMEOUT=300

# --- Production (Deploy) ---
DOMAIN=smartdatapulse.tech

# --- POS Desktop ---
# API base URL used by the POS Electron app (push.ts + main.ts).
# New installer releases: point at the dedicated POS subdomain.
# Existing pilots without this var fall back to https://smartdatapulse.tech
# (hardcoded default in push.ts) — backward compatible.
NEXT_PUBLIC_API_URL=https://pos.smartdatapulse.tech
